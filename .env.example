# PostgreSQL
POSTGRES_DB=weather_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_CONNECT_RETRIES=5
DB_CONNECT_DELAY=2.0

# Metabase
METABASE_PORT=3000

# Open-Meteo API
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF=2.0
FORECAST_DAYS=1

# Data quality bounds (Kenya hourly weather)
TEMP_MIN_C=-5
TEMP_MAX_C=45
PRECIP_MAX_MM=200
WIND_MAX_KMH=150
